---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductCard from '@components/ProductCard.astro';
import MediaFrame from '@components/MediaFrame.astro';
import { suites, productsBySuite } from '@data/catalog';

export async function getStaticPaths() {
  return suites.map((suite) => ({
    params: { slug: suite.slug },
    props: { suite },
  }));
}

const { suite } = Astro.props;
const modules = productsBySuite(suite.slug);
const liveCount = modules.filter((m) => m.status === 'live').length;
---

<BaseLayout
  title={`${suite.name} — HomesteadLabs`}
  description={suite.tagline}
>
  <!-- HERO with full-width image -->
  <section class="relative overflow-hidden border-b border-ink/10">
    <div class="relative">
      <MediaFrame
        src={suite.image}
        label={suite.name}
        aspectClass="aspect-[21/9] md:aspect-[21/7]"
        category="suite"
      />
      <!-- Color tint overlay -->
      <div
        class="absolute inset-0 mix-blend-multiply opacity-50"
        style={`background: linear-gradient(135deg, ${suite.accent}80 0%, transparent 100%);`}
      ></div>
      <!-- Bottom fade -->
      <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent"></div>
      <!-- Content overlay -->
      <div class="absolute inset-0 flex items-end">
        <div class="container-prose w-full pb-12 md:pb-20">
          <nav class="mb-6 text-eyebrow flex items-center gap-3 text-paper/60">
            <a href="/suites" class="hover:text-ember transition-colors">Suites</a>
            <span>/</span>
            <span class="text-paper">{suite.name}</span>
          </nav>
          <div class="text-eyebrow text-ember mb-4">Suite</div>
          <h1 class="font-display text-7xl md:text-9xl tracking-tightest leading-[0.92] text-paper">
            {suite.name}
          </h1>
        </div>
      </div>
    </div>
  </section>

  <!-- TAGLINE / STATUS BAR -->
  <section class="py-8 border-b border-ink/10 bg-paper-warm">
    <div class="container-prose">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <p class="font-display italic text-2xl md:text-3xl text-ember leading-snug">
          {suite.tagline}
        </p>
        <div class="flex items-center gap-4">
          <div class="text-eyebrow text-ink/40">Modules</div>
          <div class="font-mono text-sm">
            <span class="text-ember">{liveCount}</span>
            <span class="text-ink/40"> / {modules.length} LIVE</span>
          </div>
          <div class="w-32 h-1 bg-ink/10 rounded-full overflow-hidden">
            <div class="h-full bg-ember" style={`width: ${(liveCount / modules.length) * 100}%`}></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESCRIPTION -->
  <section class="py-20 md:py-32 border-b border-ink/10 mesh-subtle">
    <div class="container-prose">
      <div class="grid md:grid-cols-12 gap-8 md:gap-16">
        <div class="md:col-span-4">
          <div class="text-eyebrow text-ember mb-4">Thesis</div>
        </div>
        <div class="md:col-span-7 md:col-start-6">
          <p class="font-display text-3xl md:text-4xl leading-[1.2] tracking-tighter text-ink/90">
            {suite.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section class="py-20 md:py-32">
    <div class="container-prose">
      <div class="flex items-end justify-between mb-12">
        <div>
          <div class="text-eyebrow text-ember mb-4">Modules</div>
          <h2 class="font-display text-5xl md:text-6xl tracking-tighter leading-[0.95]">
            What's inside.
          </h2>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => <ProductCard product={m} />)}
      </div>
    </div>
  </section>
</BaseLayout>
