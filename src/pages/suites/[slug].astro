---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductCard from '@components/ProductCard.astro';
import { suites, productsBySuite } from '@data/catalog';

export async function getStaticPaths() {
  return suites.map((suite) => ({
    params: { slug: suite.slug },
    props: { suite },
  }));
}

const { suite } = Astro.props;
const modules = productsBySuite(suite.slug);
const liveCount = modules.filter((m) => m.status === 'live').length;
---

<BaseLayout
  title={`${suite.name} — HomesteadLabs`}
  description={suite.tagline}
>
  <!-- HERO -->
  <section class="py-20 md:py-32 border-b border-ink/10 relative overflow-hidden">
    <div class="grain absolute inset-0 opacity-40"></div>
    <div class="container-prose relative">
      <nav class="mb-12 text-eyebrow flex items-center gap-3 text-ink/40">
        <a href="/suites" class="hover:text-ember transition-colors">Suites</a>
        <span>/</span>
        <span class="text-ink">{suite.name}</span>
      </nav>

      <div class="grid md:grid-cols-12 gap-8 md:gap-16 items-end">
        <div class="md:col-span-8">
          <div class="text-eyebrow text-ember mb-6">Suite</div>
          <h1 class="font-display text-6xl md:text-8xl tracking-tightest leading-[0.92] mb-6">
            {suite.name}
          </h1>
          <p class="font-display italic text-2xl md:text-3xl text-ember leading-snug max-w-3xl">
            {suite.tagline}
          </p>
        </div>
        <div class="md:col-span-4 md:pt-2">
          <div class="text-eyebrow text-ink/40 mb-3">Status</div>
          <div class="font-mono text-sm text-ink/80">
            {liveCount} of {modules.length} modules live
          </div>
          <div class="mt-2 w-full h-1 bg-ink/10 rounded-full overflow-hidden">
            <div
              class="h-full bg-ember transition-all duration-1000"
              style={`width: ${(liveCount / modules.length) * 100}%`}
            ></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESCRIPTION -->
  <section class="py-20 md:py-24 border-b border-ink/10">
    <div class="container-prose">
      <div class="grid md:grid-cols-12 gap-8 md:gap-16">
        <div class="md:col-span-4">
          <div class="text-eyebrow text-ember mb-4">Thesis</div>
        </div>
        <div class="md:col-span-7 md:col-start-6">
          <p class="font-display text-3xl md:text-4xl leading-[1.2] tracking-tighter text-ink/90">
            {suite.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULES -->
  <section class="py-20 md:py-32">
    <div class="container-prose">
      <div class="flex items-end justify-between mb-12">
        <div>
          <div class="text-eyebrow text-ember mb-4">Modules</div>
          <h2 class="font-display text-5xl md:text-6xl tracking-tighter leading-[0.95]">
            What's inside.
          </h2>
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => <ProductCard product={m} />)}
      </div>
    </div>
  </section>
</BaseLayout>
