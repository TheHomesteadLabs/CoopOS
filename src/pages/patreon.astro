---
import BaseLayout from '@layouts/BaseLayout.astro';
import { patreonTiers } from '@data/catalog';

const patreonUrl = 'https://patreon.com/HomesteadLabs';
---

<BaseLayout
  title="Patreon — HomesteadLabs"
  description="Director's cuts, GitHub access, monthly board meetings. Three tiers."
>
  <!-- HERO -->
  <section class="py-20 md:py-32 border-b border-ink/10 mesh-warm relative overflow-hidden">
    <div class="grain absolute inset-0 opacity-40"></div>
    <div class="container-prose relative">
      <div class="text-eyebrow text-ember mb-6">Patreon</div>
      <h1 class="font-display text-6xl md:text-8xl tracking-tightest leading-[0.92] mb-8 max-w-4xl">
        Three tiers.<br />Three job titles.
      </h1>
      <p class="text-body-lg text-ink/70 max-w-2xl leading-relaxed">
        Patreon support gets you the depth version of HomesteadLabs.
        Director's cuts of every episode. GitHub repos for every build.
        Discord access. And, depending on tier, a seat at the board.
      </p>
    </div>
  </section>

  <!-- TIERS -->
  <section class="py-20 md:py-32">
    <div class="container-prose">
      <div class="grid md:grid-cols-3 gap-6 md:gap-8 items-start">
        {patreonTiers.map((tier, i) => (
          <div class:list={[
            'card relative overflow-hidden flex flex-col',
            i === 1 && 'ring-2 ring-ember shadow-2xl shadow-ember/10',
          ]}>
            <!-- Cover image -->
            <div class="aspect-[16/9] border-b border-ink/10 relative">
              {tier.image ? (
                <img
                  src={`/images/patreon/${tier.image}`}
                  alt={tier.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="img-placeholder absolute inset-0" data-label={tier.name}></div>
              )}
              {i === 1 && (
                <div class="absolute top-4 right-4">
                  <div class="pill pill-live bg-paper">Most popular</div>
                </div>
              )}
            </div>

            <div class="p-8 md:p-10 flex flex-col flex-1">
              <div class="text-eyebrow text-ember mb-6">Tier {String(i + 1).padStart(2, '0')}</div>

              <h3 class="font-display text-4xl tracking-tighter mb-4">
                {tier.name}
              </h3>

              <div class="flex items-baseline gap-1 mb-6">
                <span class="font-display text-5xl tracking-tighter">${tier.price}</span>
                <span class="text-sm text-ink/50 font-mono">/ month</span>
              </div>

              <p class="text-sm text-ink/65 leading-relaxed mb-8">
                {tier.blurb}
              </p>

              <ul class="space-y-3 mb-10 flex-1">
                {tier.features.map((f) => (
                  <li class="flex gap-3 text-sm text-ink/80 leading-snug">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-ember mt-0.5 shrink-0">
                      <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              
                href={patreonUrl}
                class:list={[
                  'block w-full text-center py-3 text-sm font-medium transition-all',
                  i === 1
                    ? 'bg-ember text-paper hover:bg-ember-800'
                    : 'bg-ink text-paper hover:bg-ember',
                ]}
              >
                Join {tier.name}
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="mt-16 text-xs text-ink/40 font-mono text-center max-w-xl mx-auto leading-relaxed">
        Tiers are billed monthly in USD. All Patreon-tier titles are honorary.
        No equity is granted, vested, or implied. Pam in HR has reviewed this disclosure.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-32 border-t border-ink/10 bg-paper-warm relative overflow-hidden">
    <div class="grain absolute inset-0 opacity-30"></div>
    <div class="container-prose relative">
      <div class="text-eyebrow text-ember mb-12">Frequently asked</div>
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 max-w-5xl">
        <div>
          <h3 class="font-display text-3xl tracking-tighter mb-3">
            What's the director's cut?
          </h3>
          <p class="text-base text-ink/65 leading-relaxed">
            A longer version of every episode with more failure footage,
            deeper engineering reasoning, and character beats that didn't
            make the public release.
          </p>
        </div>
        <div>
          <h3 class="font-display text-3xl tracking-tighter mb-3">
            Do I get the code?
          </h3>
          <p class="text-base text-ink/65 leading-relaxed">
            Yes. Every Patreon tier includes access to the private
            GitHub repos for each build. Hardware lists, wiring diagrams,
            and trained models included.
          </p>
        </div>
        <div>
          <h3 class="font-display text-3xl tracking-tighter mb-3">
            What's a board meeting?
          </h3>
          <p class="text-base text-ink/65 leading-relaxed">
            Director-tier members are invited to a monthly private Q&amp;A
            with Brad. We discuss the roadmap, answer engineering questions,
            and occasionally consult Pam from HR.
          </p>
        </div>
        <div>
          <h3 class="font-display text-3xl tracking-tighter mb-3">
            Can I cancel?
          </h3>
          <p class="text-base text-ink/65 leading-relaxed">
            Anytime. Patreon handles billing, cancellation, and renewals.
            Your CoopOS access is monthly, not annual.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>