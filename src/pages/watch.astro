---
import BaseLayout from '@layouts/BaseLayout.astro';
import { products } from '@data/catalog';

const episodes = [
  {
    number: 1,
    title: 'PeckPerformance',
    products: ['CoopOS', 'CoopCam', 'EggWatch', 'PeckPerformance'],
    suite: 'CoopOps',
    runtime: '14–17 min',
    status: 'In production',
    summary: 'A multi-camera computer vision system that ranks the chickens by productivity. Then ranks Brad.',
  },
  {
    number: 2,
    title: 'GrowGuard',
    products: ['GrowGuard'],
    suite: 'VegeOps',
    runtime: '12–15 min',
    status: 'Planned',
    summary: 'AI-driven drip irrigation. Soil moisture, solenoid valves, and a model that decides when to water.',
  },
  {
    number: 3,
    title: 'WeatherWatch',
    products: ['WeatherWatch'],
    suite: 'Standalone',
    runtime: '14–17 min',
    status: 'Planned',
    summary: 'A DIY weather station that learns the property\'s microclimate and outpredicts the regional forecast.',
  },
  {
    number: 4,
    title: 'CanopyControl',
    products: ['CanopyControl'],
    suite: 'VegeOps',
    runtime: '15–18 min',
    status: 'Planned',
    summary: 'A spectral sensor that sees plant stress before it shows. Then a motor that pulls shade cloth across the garden.',
  },
  {
    number: 5,
    title: 'TheDoorMan',
    products: ['TheDoorMan'],
    suite: 'CoopOps',
    runtime: '14–17 min',
    status: 'Planned',
    summary: 'A coop door that closes when sundown is imminent AND the headcount matches AND no one is in the doorway.',
  },
  {
    number: 6,
    title: 'TrailScout',
    products: ['TrailScout'],
    suite: 'PerimeterOps',
    runtime: '12–15 min',
    status: 'Planned',
    summary: 'Two ESP32-CAMs at the property edge. One AI. One hundred acres. A wildlife census builds itself.',
  },
  {
    number: 7,
    title: 'DriveWatch',
    products: ['DriveWatch'],
    suite: 'PerimeterOps',
    runtime: '13–16 min',
    status: 'Planned',
    summary: 'mmWave radar plus a camera plus a classifier. Brad gets a text before anyone reaches the door.',
  },
  {
    number: 8,
    title: 'CoopAir',
    products: ['CoopAir'],
    suite: 'CoopOps',
    runtime: '12–15 min',
    status: 'Planned',
    summary: 'Real-time air quality monitoring in the coop. Ammonia, CO₂, particulates. Pam from HR is involved.',
  },
  {
    number: 9,
    title: 'PondPulse',
    products: ['PondPulse'],
    suite: 'AquaOps',
    runtime: '16–20 min',
    status: 'Planned',
    summary: 'A floating, solar-powered pond monitor. Anchored mid-water. Transmitting via LoRa. The flagship build.',
  },
  {
    number: 10,
    title: 'HomesteadHQ',
    products: ['HomesteadHQ'],
    suite: 'Flagship',
    runtime: '15–20 min',
    status: 'Planned',
    summary: 'The unified dashboard arrives. Every module reports in. Brad presents to the board. Mark joins by video.',
  },
];
---

<BaseLayout
  title="Watch — HomesteadLabs"
  description="Episodes of HomesteadLabs on YouTube. Every product is a video."
>
<!-- HERO -->
  <section class="py-16 md:py-24 border-b border-ink/10 mesh-warm relative overflow-hidden">
    <div class="grain absolute inset-0 opacity-40"></div>
    <div class="container-prose relative">
      <div class="text-eyebrow text-ember mb-6">Watch</div>
      <h1 class="font-display text-5xl md:text-7xl tracking-tightest leading-[0.92] mb-6 max-w-4xl">
        Every product<br />is a video.
      </h1>
      <p class="text-body-lg text-ink/70 max-w-2xl leading-relaxed mb-12">
        HomesteadLabs ships modules on YouTube first. Every episode is a real
        build, end-to-end. New episode every three to four weeks.
      </p>
    </div>
  </section>

  <!-- FEATURED EPISODE -->
  <section class="py-12 md:py-20 border-b border-ink/10 bg-ink relative overflow-hidden">
    <div class="grain absolute inset-0 opacity-30 mix-blend-screen"></div>
    <div class="grid-bg-dark absolute inset-0 opacity-50"></div>
    <div class="container-prose relative">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-7">
          <!-- Trailer player placeholder -->
          <div class="aspect-video bg-paper/5 border border-paper/10 relative overflow-hidden group cursor-pointer">
            <!-- Replace this whole block with your YouTube embed once trailer is up -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-20 h-20 rounded-full bg-ember/20 border border-ember/40 flex items-center justify-center group-hover:bg-ember/40 transition-colors">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-ember ml-1">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            <div class="absolute bottom-4 left-4 text-eyebrow text-paper/60 font-mono">
              Trailer · Coming soon
            </div>
          </div>
        </div>
        <div class="lg:col-span-5">
          <div class="text-eyebrow text-ember mb-4">Now in production</div>
          <h2 class="font-display text-4xl md:text-5xl tracking-tighter leading-[0.95] text-paper mb-6">
            Episode 01:<br />PeckPerformance
          </h2>
          <p class="text-base text-paper/70 leading-relaxed mb-8">
            A multi-camera computer vision system that ranks the chickens by
            productivity. Then ranks Brad. The first module of CoopOps,
            shipping with the launch of CoopOS v1.0.
          </p>
          <div class="flex items-center gap-4 text-sm text-paper/50 font-mono">
            <span>14–17 min</span>
            <span class="text-paper/20">·</span>
            <span>CoopOps Suite</span>
            <span class="text-paper/20">·</span>
            <span>Q2 2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EPISODE LIST -->
  <section class="py-20 md:py-24">
    <div class="container-prose">
      <div class="text-eyebrow text-ember mb-12">Season 01 — 10 episodes</div>

      <ul class="divide-y divide-ink/10">
        {episodes.map((ep) => (
          <li class="group">
            <article class="grid md:grid-cols-12 gap-6 md:gap-8 py-8 md:py-10 items-start">
              <div class="md:col-span-1">
                <div class="font-display text-5xl md:text-6xl tracking-tighter text-ink/15 group-hover:text-ember transition-colors">
                  {String(ep.number).padStart(2, '0')}
                </div>
              </div>
              <div class="md:col-span-7">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-eyebrow text-ember">{ep.suite}</span>
                  <span class="text-eyebrow text-ink/30">·</span>
                  <span class="text-eyebrow text-ink/40">{ep.runtime}</span>
                </div>
                <h3 class="font-display text-3xl md:text-4xl tracking-tighter leading-[1] mb-3">
                  {ep.title}
                </h3>
                <p class="text-base text-ink/65 leading-relaxed max-w-2xl">
                  {ep.summary}
                </p>
              </div>
              <div class="md:col-span-3 md:col-start-10 flex md:justify-end">
                <div class:list={['pill', ep.status === 'In production' ? 'pill-live' : 'pill-soon']}>
                  {ep.status}
                </div>
              </div>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
