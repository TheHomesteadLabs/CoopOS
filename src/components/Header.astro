---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Products', href: '/products' },
  { label: 'Suites', href: '/suites' },
  { label: 'Watch', href: '/watch' },
  { label: 'Patreon', href: '/patreon' },
  { label: 'About', href: '/about' },
];
---

<header class="sticky top-0 z-50 bg-paper/80 backdrop-blur-md border-b border-ink/10">
  <div class="container-prose">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <!-- Logomark: minimal geometric mark, hand-drawn-feeling -->
        <svg
          width="28"
          height="28"
          viewBox="0 0 32 32"
          fill="none"
          class="transition-transform duration-500 group-hover:rotate-180"
        >
          <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" class="text-ink" />
          <path
            d="M10 22 L10 13 L16 9 L22 13 L22 22 M14 22 L14 17 L18 17 L18 22"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="square"
            stroke-linejoin="miter"
            fill="none"
            class="text-ember"
          />
        </svg>
        <span class="font-display text-xl tracking-tight text-ink">
          HomesteadLabs
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors duration-300 link-underline',
                currentPath.startsWith(item.href) ? 'text-ember' : 'text-ink/70 hover:text-ink',
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA -->
      <a href="/products/coopos" class="hidden md:inline-flex btn-primary text-xs px-4 py-2">
        Get CoopOS
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        aria-label="Toggle navigation"
        class="md:hidden p-2 -mr-2"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="square" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-ink/10 pt-4">
      <ul class="flex flex-col gap-4">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block text-sm font-medium',
                  currentPath.startsWith(item.href) ? 'text-ember' : 'text-ink/70',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/products/coopos" class="btn-primary w-full justify-center mt-2">
            Get CoopOS →
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
