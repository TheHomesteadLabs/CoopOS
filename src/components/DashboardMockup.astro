---
// CSS-rendered dashboard mockup. No external image needed.
// Looks like the real PeckPerformance dashboard from Episode 1.
---

<div class="mockup-tilt floating w-full">
  <!-- Browser chrome -->
  <div class="bg-ink rounded-t-lg overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 border-b border-paper/10">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-paper/20"></div>
        <div class="w-3 h-3 rounded-full bg-paper/20"></div>
        <div class="w-3 h-3 rounded-full bg-paper/20"></div>
      </div>
      <div class="flex-1 flex justify-center">
        <div class="bg-paper/5 px-3 py-1 rounded text-paper/40 font-mono text-[10px]">
          coopos.local:8501
        </div>
      </div>
      <div class="text-paper/40 font-mono text-[10px]">
        v1.0.0
      </div>
    </div>

    <!-- Dashboard body -->
    <div class="bg-ink p-6 grid-bg-dark">
      <!-- Header row -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <div class="font-mono text-[10px] uppercase tracking-wider text-ember mb-1">PeckPerformance</div>
          <div class="font-display text-2xl text-paper">Q1 2026 — Productivity</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="bg-ember/10 border border-ember/30 px-3 py-1 rounded text-ember text-[10px] font-mono">
            ● LIVE
          </div>
          <div class="bg-paper/5 border border-paper/10 px-3 py-1 rounded text-paper/60 text-[10px] font-mono">
            SHOW HUMANS: ON
          </div>
        </div>
      </div>

      <!-- Stat row -->
      <div class="grid grid-cols-4 gap-3 mb-6">
        <div class="bg-paper/5 border border-paper/10 rounded p-3">
          <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-2">Total Eggs</div>
          <div class="font-display text-2xl text-paper">847</div>
          <div class="text-ember text-[10px] font-mono mt-1">+3.2%</div>
        </div>
        <div class="bg-paper/5 border border-paper/10 rounded p-3">
          <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-2">Active Birds</div>
          <div class="font-display text-2xl text-paper">63</div>
          <div class="text-paper/40 text-[10px] font-mono mt-1">+ 1 human</div>
        </div>
        <div class="bg-paper/5 border border-paper/10 rounded p-3">
          <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-2">Coop Visits</div>
          <div class="font-display text-2xl text-paper">12,481</div>
          <div class="text-ember text-[10px] font-mono mt-1">+ 47 (BC)</div>
        </div>
        <div class="bg-paper/5 border border-paper/10 rounded p-3">
          <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-2">Productivity</div>
          <div class="font-display text-2xl text-paper">94%</div>
          <div class="text-ember text-[10px] font-mono mt-1">Strong</div>
        </div>
      </div>

      <!-- Chart -->
      <div class="bg-paper/5 border border-paper/10 rounded p-4 mb-6">
        <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-3">Daily Egg Production — 30 days</div>
        <svg viewBox="0 0 400 80" class="w-full h-16">
          <!-- Background grid -->
          <line x1="0" y1="20" x2="400" y2="20" stroke="rgba(250,250,247,0.05)" stroke-width="1"/>
          <line x1="0" y1="40" x2="400" y2="40" stroke="rgba(250,250,247,0.05)" stroke-width="1"/>
          <line x1="0" y1="60" x2="400" y2="60" stroke="rgba(250,250,247,0.05)" stroke-width="1"/>
          <!-- Area fill -->
          <path
            d="M0,55 L13,52 L27,48 L40,50 L53,45 L67,42 L80,46 L93,40 L107,38 L120,35 L133,32 L147,28 L160,30 L173,25 L187,28 L200,22 L213,24 L227,20 L240,18 L253,22 L267,16 L280,20 L293,14 L307,18 L320,12 L333,16 L347,10 L360,14 L373,8 L387,12 L400,8 L400,80 L0,80 Z"
            fill="rgba(194,65,12,0.15)"
          />
          <!-- Line -->
          <path
            d="M0,55 L13,52 L27,48 L40,50 L53,45 L67,42 L80,46 L93,40 L107,38 L120,35 L133,32 L147,28 L160,30 L173,25 L187,28 L200,22 L213,24 L227,20 L240,18 L253,22 L267,16 L280,20 L293,14 L307,18 L320,12 L333,16 L347,10 L360,14 L373,8 L387,12 L400,8"
            fill="none" stroke="#C2410C" stroke-width="1.5"
          />
          <!-- End dot -->
          <circle cx="400" cy="8" r="3" fill="#C2410C"/>
          <circle cx="400" cy="8" r="6" fill="#C2410C" fill-opacity="0.3"/>
        </svg>
      </div>

      <!-- Leaderboard -->
      <div>
        <div class="text-paper/40 text-[9px] font-mono uppercase tracking-wider mb-3">Productivity Ranking — Q1</div>
        <div class="space-y-1">
          <!-- Row 1 — top performer -->
          <div class="flex items-center justify-between py-1.5 px-3 bg-paper/[0.03] rounded text-[11px]">
            <div class="flex items-center gap-3">
              <span class="text-ember font-mono w-4">01</span>
              <span class="text-paper">HENRIETTA</span>
              <span class="text-paper/40 font-mono text-[9px]">Buff Orpington</span>
            </div>
            <div class="flex items-center gap-4 font-mono">
              <span class="text-paper/60">14 eggs</span>
              <span class="text-ember">★★★★★</span>
            </div>
          </div>
          <!-- Row 2 -->
          <div class="flex items-center justify-between py-1.5 px-3 bg-paper/[0.03] rounded text-[11px]">
            <div class="flex items-center gap-3">
              <span class="text-paper/60 font-mono w-4">02</span>
              <span class="text-paper">DEBRA 2</span>
              <span class="text-paper/40 font-mono text-[9px]">Black Australorp</span>
            </div>
            <div class="flex items-center gap-4 font-mono">
              <span class="text-paper/60">12 eggs</span>
              <span class="text-paper/60">★★★★☆</span>
            </div>
          </div>
          <!-- Row 3 -->
          <div class="flex items-center justify-between py-1.5 px-3 bg-paper/[0.03] rounded text-[11px]">
            <div class="flex items-center gap-3">
              <span class="text-paper/60 font-mono w-4">03</span>
              <span class="text-paper">JACK</span>
              <span class="text-paper/40 font-mono text-[9px]">Rooster</span>
            </div>
            <div class="flex items-center gap-4 font-mono">
              <span class="text-paper/60">— eggs</span>
              <span class="text-paper/60">★★★★☆</span>
            </div>
          </div>
          <!-- Spacer -->
          <div class="text-paper/30 text-[9px] font-mono py-1 px-3">... 12 more rows</div>
          <!-- Last row — Brad -->
          <div class="flex items-center justify-between py-1.5 px-3 bg-ember/15 border border-ember/40 rounded text-[11px]">
            <div class="flex items-center gap-3">
              <span class="text-ember font-mono w-4">16</span>
              <span class="text-ember">BRAD CONLIN</span>
              <span class="text-ember/60 font-mono text-[9px]">Human</span>
            </div>
            <div class="flex items-center gap-4 font-mono">
              <span class="text-ember/80">0 eggs</span>
              <span class="text-ember">WORST</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
