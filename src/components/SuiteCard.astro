---
import type { Suite } from '@data/catalog';
import { products as allProducts } from '@data/catalog';
import MediaFrame from './MediaFrame.astro';

export interface Props {
  suite: Suite;
}

const { suite } = Astro.props;
const modules = allProducts.filter((p) => suite.modules.includes(p.slug));
const liveCount = modules.filter((m) => m.status === 'live').length;
---

<a
  href={`/suites/${suite.slug}`}
  class="card group block"
>
  <!-- Image with accent overlay -->
  <div class="relative">
    <MediaFrame
      src={suite.image}
      label={suite.name}
      aspectClass="aspect-[16/9]"
      category="suite"
    />
    <!-- Accent gradient overlay -->
    <div
      class="absolute inset-0 opacity-30 mix-blend-multiply"
      style={`background: linear-gradient(135deg, ${suite.accent}40 0%, transparent 60%);`}
    ></div>
    <!-- Suite name overlay -->
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 bg-gradient-to-t from-ink/80 to-transparent">
      <div class="text-eyebrow text-paper/70 mb-1">Suite</div>
      <h3 class="font-display text-4xl md:text-5xl tracking-tighter text-paper leading-[1]">
        {suite.name}
      </h3>
    </div>
  </div>

  <!-- Body -->
  <div class="p-6 md:p-8">
    <p class="text-base text-ink/70 leading-relaxed mb-6 max-w-md">
      {suite.tagline}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {modules.map((m) => (
        <span class:list={[
          'text-xs px-3 py-1 rounded-full border',
          m.status === 'live'
            ? 'border-ember/30 text-ember bg-ember/5'
            : 'border-ink/15 text-ink/55'
        ]}>
          {m.name}
        </span>
      ))}
    </div>

    <div class="pt-6 border-t border-ink/10 flex items-center justify-between">
      <span class="text-xs font-mono text-ink/40">
        {liveCount}/{modules.length} MODULES LIVE
      </span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-ink/40 group-hover:text-ember transition-colors">
        <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </div>
</a>
